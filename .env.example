# ── Server (runtime) ──────────────────────────────────────────
PORT=3001
NODE_ENV=development
ADMIN_PASSWORD=change-me-before-deploy
# Set when you purchase a domain:
SITE_URL=

# Vercel production: add Upstash Redis from Vercel Marketplace (Storage → Redis)
# These are auto-injected when you connect the integration:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: local file DB path (default: ./data/pilotpay.json)
# DATABASE_PATH=./data/pilotpay.json

# ── Form notifications (Vercel + local) ───────────────────────
# Email goes to NOTIFY_EMAIL (default: boukharih262@gmail.com)
NOTIFY_EMAIL=boukharih262@gmail.com
# Resend API key — https://resend.com/api-keys (free tier works)
RESEND_API_KEY=
# Optional custom sender after domain verification on Resend
# NOTIFY_EMAIL_FROM=PilotPay <onboarding@yourdomain.com>

# Telegram bot — messages @Loulou134 after they press Start on the bot
# 1) Message @BotFather → /newbot → copy token
# 2) @Loulou134 opens t.me/YourBotName and taps Start
# 3) Open https://api.telegram.org/bot<TOKEN>/getUpdates → copy "chat":{"id":...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Client (build-time, VITE_ prefix) ─────────────────────────
# Leave empty until domain is purchased — site uses window.location.origin
VITE_SITE_URL=

# Override only if API is hosted separately (default: /api/onboarding)
# VITE_APPLY_ENDPOINT=/api/onboarding

VITE_CONTACT_EMAIL=contact@pilotpay.com
