# ── Server (runtime) ──────────────────────────────────────────
PORT=3001
NODE_ENV=development
ADMIN_PASSWORD=change-me-before-deploy
# Set when you purchase a domain:
SITE_URL=

# Vercel production: add Upstash Redis from Vercel Marketplace (Storage → Redis)
# These are auto-injected when you connect the integration:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: local file DB path (default: ./data/pilotpay.json)
# DATABASE_PATH=./data/pilotpay.json

# ── Client (build-time, VITE_ prefix) ─────────────────────────
# Leave empty until domain is purchased — site uses window.location.origin
VITE_SITE_URL=

# Override only if API is hosted separately (default: /api/onboarding)
# VITE_APPLY_ENDPOINT=/api/onboarding

VITE_CONTACT_EMAIL=contact@pilotpay.com
